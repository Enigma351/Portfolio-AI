# Partha.OS - Production Environment Template

# 1. API Configuration
# Point this to your hosted backend (e.g., https://api-partha-os.vercel.app/api)
VITE_API_BASE_URL=http://localhost:5000/api

# 2. AI Engine Configuration
# If left empty, the OS automatically falls back to the high-performance 'Neural Mock Engine'
# This ensures 100% functionality even during development or sandbox testing.
VITE_OPENAI_API_KEY=

# 3. Deployment Notes:
# - Ensure CORS is enabled on the server for your frontend domain.
# - The OS kernel (Zustand) is optimized for build-time minification.
# - Individual app modules are lazy-loaded on demand.
